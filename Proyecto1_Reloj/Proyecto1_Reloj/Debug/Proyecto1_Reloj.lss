                                 #pragma AVRPART MEMORY EEPROM 1024
                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x100
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 * Proyecto1_Reloj.asm
                                 *
                                 * Creado: 3/03/2026 14:18:03
                                 * Autor : MarĂ­a Olga Joachin
                                 * DescripciĂłn: Funcionamiento de un reloj con 4 displays de 7 segmentos
                                 el cual estarĂˇ controlado por 4 pushbuttons, uno para el cambio de configuracion
                                 mientras que los otro 4 para el incremento y decremento de los displays. 
                                 */
                                 /****************************************/
                                 
                                 // Encabezado (DefiniciĂłn de Registros, Variables y Constantes)
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 
                                 .def temp           = r16		 // Registro temporal de uso general
                                 .def num_a_mostrar  = r18		 // Numero del los digitos que se mostraran en el display, 0 a 9
                                 .def estado         = r25    	 // Estado actual del reloj 
                                 .def en_config      = r19    	 // Banderas para verificar el estado de configuraciĂłn
                                 .def disp_select    = r24    	 // Indica cual de los display esta siendo activado
                                 
                                 //variable_name:     .byte   1   // Memory alocation for variable_name:     .byte   (byte size)
                                 .dseg
                                 .org 0x0100
000100                           segundos:			 .byte 1	 // Almacena los segundos actuales
000101                           minutos:			 .byte 1	 // Almacena los minutos actuales
000102                           horas:				 .byte 1	 // Almacena la hora actual
000103                           dia:				 .byte 1	 // Almacena el dia del mes actual
000104                           mes:				 .byte 1	 // Almacena el mes actual
000105                           alarma_horas:		 .byte 1	 // Hora de configuraciĂłn para la alarma (0 a 23)
000106                           alarma_minutos:		 .byte 1	 // Minuto de configuraciĂłn para la alarma (0 a 59)
000107                           alarma_activa:		 .byte 1	 // Bandera para activar la alarma
000108                           cont_ms:			 .byte 1     // Contador de milisegundos para el parpadeo de los LEDs
000109                           cont_ms2:			 .byte 1     // Contador de milisegundos para el estado de la alarma
00010a                           digito0:			 .byte 1     // Valor del digito del Display 1
00010b                           digito1:			 .byte 1     // Valor del digito del Display 2
00010c                           digito2:			 .byte 1     // Valor del digito del Display 3
00010d                           digito3:			 .byte 1     // Valor del digito del Display 4
                                 
                                 // Vectores de interrupciĂłn
                                 .cseg
                                 .org 0x0000
000000 c038                          rjmp Setup
                                 
                                 .org 0x0006                  // PCINT1 - Botones Puerto C
000006 c156                          rjmp PCI1_ISR
                                 
                                 .org 0x001A                  // Timer1 Compare Match A - 1 segundo
00001a c0a8                          rjmp TIM1_COMPA_ISR
                                 
                                 .org 0x001C                  // Timer0 Compare Match A - 1ms multiplexado
00001c c0c0                          rjmp TIM0_COMPA_ISR
                                 
                                 // Tabla de 7 segmentos (Display CĂˇtodo ComĂşn)
                                 .org 0x0034
                                 Tabla7Seg:
000034 063f
000035 4f5b
000036 6d66
000037 077d
000038 6f7f                          .DB 0x3F, 0x06, 0x5B, 0x4F, 0x66, 0x6D, 0x7D, 0x07, 0x7F, 0x6F
                                 
                                 /****************************************/
                                 // ConfiguraciĂłn de la pila
                                 Setup:
                                     // InicializaciĂłn del stack
000039 ef0f                          ldi temp, low(RAMEND)
00003a bf0d                          out SPL, temp
00003b e008                          ldi temp, high(RAMEND)
00003c bf0e                          out SPH, temp
                                 
                                 /****************************************/
                                 // Configuracion MCU
                                 
                                     // ConfiguraciĂłn de Puertos
                                     // DDRB: PB0-PB5 salidas 
00003d e30f                          ldi temp, 0b00111111					// Se escriben de PB0 a PB5 como salidas
00003e b904                          out DDRB, temp							// Se escribe la configuraciĂłn en el registro del Puerto B
                                 
                                 	// DDRD: PD2-PD7 salidas 
00003f ef0c                      	ldi temp, 0b11111100					// Se escriben de PD2 a PD7 como salidas
000040 b90a                      	out DDRD, temp							// Se escribe la configuraciĂłn en el registro del Puerto D
                                 	
                                 	// DDRC: PC5 salida (buzzer), PC0-PC4 entradas (botones)
000041 e200                      	ldi temp, 0b00100000					// Se escriben PC5 como salida del buzzer y PC0 a PC4 como entradas 
000042 b907                      	out DDRC, temp							// Se escribe la configuraciĂłn en el registro del Puerto C
                                 	
                                 	// Pull-ups botones PC0-PC4, PC5 apagado al inicio
000043 e10f                      	ldi temp, 0b00011111					// Habilita el pull-up interno
000044 b908                      	out PORTC, temp							// Se escribe en PORTC 
                                 
                                     // Apagar displays al inicio
000045 2700                          clr temp								// Limpieza del registro
000046 b905                          out PORTB, temp							// Se apagan todos los segmentos del Puerto B
000047 b90b                          out PORTD, temp							// Se apagan los pines del Puerto D
                                 
                                     // ConfiguraciĂłn del Timer0
                                     ; CTC, prescaler 64, OCR0A=249 => 1ms @ 16MHz
000048 e002                          ldi temp, (1 << WGM01)					// Modo CTC, el temporizador se reinicia cuando llega al valor de OCR0A
000049 bd04                          out TCCR0A, temp						// ConfiguraciĂłn del registro de control A del Timer0
00004a e003                          ldi temp, (1 << CS01) | (1 << CS00)		// Se usa un prescaler de 64
00004b bd05                          out TCCR0B, temp						// ConfiguraciĂłn del registro de control B del Timer0 con el prescaler
00004c ef09                          ldi temp, 249							// El valro a comparar para una interrupcion de 1ms
00004d bd07                          out OCR0A, temp							// Se carga el valor de comparaciĂłn del Timer0
00004e e002                          ldi temp, (1 << OCIE0A)					// Se habilita la interrupciĂłn del Timer0
00004f 9300 006e                     sts TIMSK0, temp						// Se escribe en el registro de mascara de interrupciones del Timer0
                                 
                                     // Configurar Timer1
                                     // CTC, prescaler 1024, OCR1A=15624 => 1s @ 16MHz
000051 e30d                          ldi temp, high(15624)					// Valor alto de comparaciĂłn para 1 segundo
000052 9300 0089                     sts OCR1AH, temp						// Carga el byte alto de OCR1A en la memoria
000054 e008                          ldi temp, low(15624)					// Valor bajo de comparaciĂłn para 1 segundo
000055 9300 0088                     sts OCR1AL, temp						// Carga el byte bajo de OCR1A en la memoria
000057 e00d                          ldi temp, (1 << WGM12) | (1 << CS12) | (1 << CS10)		// Modo CTC con prescaler de 1024
000058 9300 0081                     sts TCCR1B, temp						// ConfiguraciĂłn del Timer1 con prescaler 1024
00005a e002                          ldi temp, (1 << OCIE1A)					// Se habilita la interrupciĂłn por comparaciĂłn del Timer 1
00005b 9300 006f                     sts TIMSK1, temp						// Se escribe el registro de mĂˇscara de interrupciones para el Timer 1
                                 
                                     // Configurar PCINT1 - Botones PC0-PC4
00005d e002                          ldi temp, (1 << PCIE1)					// Se habilitan las insterrupciones por cambio del pin en el Puerto C
00005e 9300 0068                     sts PCICR, temp							// Se escribe en el registro de control de interrupciones
000060 e10f                          ldi temp, 0b00011111					// Se habilita PCINT para PC0 a PC4
000061 9300 006c                     sts PCMSK1, temp						// Se escriba la mĂˇscara de pines a monitorear en Puerto C
                                 
                                     // Inicializar variables
000063 e000                          ldi temp, 0x00							// Valor inicial es 0
000064 9300 0100                     sts segundos, temp						// InicializaciĂłn de segundos en 0
000066 9300 0101                     sts minutos, temp						// InicializaciĂłn de minutos en 0
000068 9300 0102                     sts horas, temp							// InicializaciĂłn de horas en 0
00006a 9300 0108                     sts cont_ms, temp						// InicializaciĂłn del contador de milisegundos en 0
00006c 9300 0109                     sts cont_ms2, temp						// InicializaciĂłn del contador de milisegundos para la alarma en 0
00006e 9300 0107                     sts alarma_activa, temp					// InicializaciĂłn de la bandera para activar la alarma en 0
000070 9300 0105                     sts alarma_horas, temp					// InicializaciĂłn de hora de la alarma en 0
000072 9300 0106                     sts alarma_minutos, temp				// InicializaciĂłn de minutos de la alarma en 0
                                     
                                     // Inicializar todos los digitos a 0
000074 9300 010a                     sts digito0, temp						// Display 1 inicia mostrando 0
000076 9300 010b                     sts digito1, temp						// Display 2 inicia mostrando 0
000078 9300 010c                     sts digito2, temp						// Display 3 inicia mostrando 0
00007a 9300 010d                     sts digito3, temp						// Display 4 inicia mostrando 0
                                     
00007c e001                          ldi temp, 1								// Valor inicial para dia y mes siendo 1
00007d 9300 0103                     sts dia, temp							// InicializaciĂłn dia en 1
00007f 9300 0104                     sts mes, temp							// InicializaciĂłn mes en 1
                                 
                                     // Inicializar registros
000081 2799                          clr estado								// Estado inicial en 0 (para visualizar la hora)
000082 2733                          clr en_config							// El reloj comienza a correr
000083 2788                          clr disp_select							// Empieza el display 0 en el multiplexado
000084 9478                          sei										// Habilita interrupciones globales 
                                 
                                 /****************************************/
                                 // Loop Infinito
                                 
                                 MainLoop:
000085 d001                          rcall Actualizar_Digitos				// Llama a la subrutina pata actualizar los digitos segun el modo actual
000086 cffe                          rjmp  MainLoop							// Bucle principal
                                 
                                 /****************************************/
                                 // NON-Interrupt subroutines
                                 // ActualizaciĂłn de dĂ­gitos para los displays
                                 Actualizar_Digitos:
000087 3091                          cpi  estado, 1							// Compara estado 1 (fecha)
000088 f0a1                          breq Mostrar_Fecha						// Si el estado == 1, salta a mostrar la fecha
000089 3093                          cpi  estado, 3         					// Compara estado 3 (configuraciĂłn de fecha)
00008a f091                          breq Mostrar_Fecha      				// Si el estado == 3, salta a mostrar la fecha
00008b 3094                          cpi  estado, 4							// Compara estado 4 configuraciĂłn de alarma)
00008c f0f9                          breq Mostrar_Alarma						// Si el estado == 4, salta a mostrar la alarma
00008d c000                          rjmp Mostrar_Hora						// En los otros casos como estado 0 o 2, muestra la hora
                                 
                                 Mostrar_Hora:
00008e 9100 0102                     lds     temp, horas						// Carga el valoor de horas desde la RAM
000090 d02a                          rcall   Separar_Digitos					// Separa las decenas y las unidades 
000091 9350 010a                     sts     digito0, r21					// Guarda decenas de hora en el Display 1
000093 9360 010b                     sts     digito1, r22					// Guarda unidades de hora en el Display 2
000095 9100 0101                     lds     temp, minutos					// Carga el valor de munutos desde la RAM
000097 d023                          rcall   Separar_Digitos					// Guarda decenas de minuto en el Display 3
000098 9350 010c                     sts     digito2, r21					// Guarda unidades de minuto en el Display 4
00009a 9360 010d                     sts     digito3, r22					// Retorna
00009c 9508                          ret
                                 
                                 Mostrar_Fecha:
00009d 9100 0103                     lds     temp, dia						// Carga el valor del dia desde la RAM
00009f d01b                          rcall   Separar_Digitos					// Separa las decenas y las unidades
0000a0 9350 010a                     sts     digito0, r21					// Guarda decenas de dia en el Display 1
0000a2 9360 010b                     sts     digito1, r22					// Guarda unidades de dia en el Display 2
0000a4 9100 0104                     lds     temp, mes						// Carga el valor del mes desde la RAM
0000a6 d014                          rcall   Separar_Digitos					// Separa las decenas y las unidades
0000a7 9350 010c                     sts     digito2, r21					// Guarda decenas del mes en el Display 3
0000a9 9360 010d                     sts     digito3, r22					// Guarda unidades del mes en el Display 4
0000ab 9508                          ret										// Retorna
                                 
                                 Mostrar_Alarma:
0000ac 9100 0105                     lds     temp, alarma_horas				// Carga el valor de la alarma desde la RAM
0000ae d00c                          rcall   Separar_Digitos					// Separa las decenas y las unidades
0000af 9350 010a                     sts     digito0, r21					// Guarda decenas de hora de alarma en el Display 1
0000b1 9360 010b                     sts     digito1, r22					// Guarda unidades de hora de alarma en el Display 2
0000b3 9100 0106                     lds     temp, alarma_minutos			// Carga el valor del mes desde la RAM
0000b5 d005                          rcall   Separar_Digitos					// Separa las decenas y las unidades
0000b6 9350 010c                     sts     digito2, r21					// Guarda decenas de minuto de alarma en el Display 3
0000b8 9360 010d                     sts     digito3, r22					// Guarda unidades de minuto de alarma en el Display 4
0000ba 9508                          ret										// Retorna
                                 
                                 // SeparaciĂłn de dĂ­gitos
                                 Separar_Digitos:
0000bb 2755                          clr     r21								// Inicializa el contador de decenas en 0
                                 Sep_Loop:
0000bc 300a                          cpi     temp, 10						// Compara el numero restante con 10
0000bd f018                          brlo    Sep_Fin							// Si es menor que 10, ya esta las unidades en temo
0000be 500a                          subi    temp, 10						// Resta 10 al numero (uya que equivale a extraer una decena)
0000bf 9553                          inc     r21								// Incrementa el contador de decenas
0000c0 cffb                          rjmp    Sep_Loop						// Repite hasta que temp sea menor que 10
                                 Sep_Fin:
0000c1 2f60                          mov     r22, temp						// El resto (osea 0 a 9) son las unidades
0000c2 9508                          ret										// Retorna con decenas y unidades (en registros r21 y r22 respectivamente)
                                 
                                 /****************************************/
                                 // Interrupt routines
                                 // ISR Timer1 - Avance del reloj
                                 TIM1_COMPA_ISR:				
0000c3 930f                          push temp								// Guarda el registro temp en la pila
0000c4 b70f                          in   temp, SREG							// Lee el registro de estado del procesador
0000c5 930f                          push temp								// Guarda SREG en la pila para restaurarlo despues
0000c6 934f                      	push r20								// Guarda r20 en la pila (usado para incrementar)
0000c7 935f                      	push r21								// Guarda r21 en la pĂ­la (usado para incrementar)
                                 											
0000c8 2f03                          mov  temp, en_config     				// Copia la bandera de configuraciĂłn a temp
0000c9 2300                          tst  temp								// Verifica si la bandera es cero (osea si el reloj esta corriendo)
0000ca f461                          brne Salir_T1							// Si en_config es distinto de 0, no avanza el tiempo
                                 											
0000cb 9100 0100                     lds  temp, segundos						// Se carga el valor actual de segundos desde la RAM
0000cd 9503                          inc  temp								// Incrementa los segundos de 1 en 1
0000ce 330c                          cpi  temp, 60							// Compara con 60 ya que es el limite de los segundos (indica overflow)
0000cf f429                          brne Guardar_Seg						// Si no llega a 60, guarda y termina
0000d0 2700                          clr  temp								// Si llego a 60, reinicia a 0 segundos
0000d1 9300 0100                     sts  segundos, temp						// Guarda segundos en 0
0000d3 d0da                          rcall Inc_Minutos						// Llama a la rutina de incremento de minutos 
0000d4 c002                          rjmp Salir_T1							// Salta a la final de la ISR 
                                 
                                 Guardar_Seg:								
0000d5 9300 0100                     sts  segundos, temp						// Guarda el nuevo valor de segundos en la RAM
                                 
                                 Salir_T1:
0000d7 915f                          pop r21									// Restaura r21 desde la pila
0000d8 914f                      	pop r20									// Restaura r20 desde la pila
0000d9 910f                      	pop  temp								// Restaura el valor de SREG que se guardo
0000da bf0f                          out  SREG, temp							// Restaura el registro de estado del procesador
0000db 910f                          pop  temp								// Restaura el registro temp original 
0000dc 9518                          reti									// Retorna de la interrupciĂłn y re-habilita las interrupciones
                                 
                                 // ISR Timer1 - Multiplexado de los displays
                                 TIM0_COMPA_ISR:
0000dd 930f                          push temp								// Guarda temp en la pila
0000de b70f                          in   temp, SREG							// Lee el registro de estado
0000df 930f                          push temp								// Guarda SREG en la pila
0000e0 932f                          push num_a_mostrar						// Guarda el registro de digito actual
0000e1 934f                          push r20								// Guarda r20 para operaciones de puerto
0000e2 935f                          push r21								// Guarda r21 para el uso de mĂˇscara XOR
                                 
                                     // Apagar SOLO transistores (PD2-PD5)
0000e3 b10b                          in   temp, PORTD						// Lee el estado actual del Puerto D
0000e4 7c03                          andi temp, 0b11000011					// Apaga PD2 a PD5 
0000e5 b90b                          out  PORTD, temp						// Escribe el resultado, desactiva todos los displays
                                 
                                     // Cargar digito segun display actual
0000e6 3080                          cpi  disp_select, 0						// Compara el display actual con 0
0000e7 f029                          breq ISR_D0								// Si es el Display 0, salta a cargarlo
0000e8 3081                          cpi  disp_select, 1						// Compara con 1
0000e9 f031                          breq ISR_D1								// Si es el Display 1, salta a cargarlo
0000ea 3082                          cpi  disp_select, 2						// Compara con 2
0000eb f039                          breq ISR_D2								// Si es el Display 2, salta a cargarlo
0000ec c009                          rjmp ISR_D3								// Si es 3, carga el Display 3
                                 
                                 ISR_D0:
0000ed 9120 010a                     lds  num_a_mostrar, digito0				// Carga el digito 0 en decenas de hora/dia al mostrarlo
0000ef c008                          rjmp ISR_Enviar							// Salta a enviar el digito a los puertos
                                 
                                 ISR_D1:
0000f0 9120 010b                     lds  num_a_mostrar, digito1				// Carga el digito 1 en unidades de hora/dia al mostrarlo
0000f2 c005                          rjmp ISR_Enviar							// Salta a enviar el digito a los puertos
                                 
                                 ISR_D2:
0000f3 9120 010c                     lds  num_a_mostrar, digito2				// Carga el digito 2 en decenas de minutos/mes al mostrarlo
0000f5 c002                          rjmp ISR_Enviar							// Salta a enviar el digito a los puertos
                                 
                                 ISR_D3:
0000f6 9120 010d                     lds  num_a_mostrar, digito3				// Carga el digito 3 en unidades minutos/mes al mostrarlo
                                 
                                 ISR_Enviar:
0000f8 d041                          rcall Enviar_a_Puertos					// Llama a la subrutina para enviar las seĂ±ales a los degmentos del display
                                 
                                     // Activar transistor correspondiente
0000f9 3080                          cpi  disp_select, 0						// Verifica si el display actual esta es el 0
0000fa f029                          breq ISR_T1								// Si es 0, activa el transistor del Display 1
0000fb 3081                          cpi  disp_select, 1						// Verifica si el display actual esta es el 1
0000fc f029                          breq ISR_T2								// Si es 0, activa el transistor del Display 2 
0000fd 3082                          cpi  disp_select, 2						// Verifica si el display actual esta es el 2 
0000fe f029                          breq ISR_T3								// Si es 0, activa el transistor del Display 3
0000ff c006                          rjmp ISR_T4								// Si es 3, activa el transistor del Display 4
                                 
                                 ISR_T1:
000100 9a5d                          sbi  PORTD, 5							// Activa PD5, enciende el transistor del Display 1
000101 c005                          rjmp ISR_Fin							// Salta al final del manjeo de transistores
                                 
                                 ISR_T2:
000102 9a5c                          sbi  PORTD, 4							// Activa PD4, enciende el transistor del Display 1
000103 c003                          rjmp ISR_Fin							// Salta al final del manjeo de transistores
                                 
                                 ISR_T3:
000104 9a5b                          sbi  PORTD, 3							// Activa PD3, enciende el transistor del Display 1
000105 c001                          rjmp ISR_Fin							// Salta al final del manjeo de transistores
                                 
                                 ISR_T4:
000106 9a5a                          sbi  PORTD, 2							// Activa PD2, se enciende el transistor del Display 4
                                 
                                 ISR_Fin:
                                     // Avanzar display
000107 9583                          inc  disp_select						// Incrementa el indice del display activo
000108 7083                          andi disp_select, 0x03					// Mantiene el valor en rango de 0 a 3 
                                 
                                     // Parpadeo PB5 segun estado
000109 9100 0108                     lds  temp, cont_ms						// Carga el contador de milisegundos del parpadeo
00010b 9503                          inc  temp								// Incrementa el contador en 1
                                 
00010c 3094                          cpi  estado, 4							// Verifica si el estado es 4 (el de la alarma)
00010d f051                          breq Chk_Rapido							// Si es estado 4, usa parpadeo rĂˇpido-
                                 
                                 Chk_Lento:
00010e 3c08                          cpi  temp, 200							// Verifica si han pasado 200ms 
00010f f489                          brne Guardar_Cont						// Si no llegamos a 200ms, guarda y continua 
000110 2700                          clr  temp								// Reincia el contador de milisegundos
000111 3092                          cpi  estado, 2							// Verifica si el estado es menor que 2 (modo normal)
000112 f068                          brlo LED_Fijo							// Si estado es menor a 2, el Led permanece fijo (indicado fecha u hora)
000113 b145                          in   r20, PORTB							// Lee el estado actual del Puerto B
000114 e250                          ldi  r21, (1 << PB5)					// Prepara mascara para el bit PB5 
000115 2745                          eor  r20, r21							// Alterna el bit PB5
000116 b945                          out  PORTB, r20							// Escribe el nuevo estado con PB5 alternado
000117 c009                          rjmp Guardar_Cont						// Salta a guardar el contador
                                 
                                 Chk_Rapido:
000118 310e                          cpi  temp, 30							// Verifica si han pasado 30 ms (parpadeo rĂˇpido para el arma)
000119 f439                          brne Guardar_Cont						// Si no, guarda y continua 
00011a 2700                          clr  temp								// Reinicia el contador
00011b b145                          in   r20, PORTB							// Lee el estado del Puerto B
00011c e250                          ldi  r21, (1 << PB5)					// Prepara mascara para PB5
00011d 2745                          eor  r20, r21							// Alterna el LED dos puntos rapidamente
00011e b945                          out  PORTB, r20							// Escribe el nuevo estado
00011f c001                          rjmp Guardar_Cont						// Salta a guardar el contador
                                 
                                 LED_Fijo:
000120 9a2d                          sbi  PORTB, 5							// Enciende el LED PB5 de forma fija
                                 
                                 Guardar_Cont:
000121 9300 0108                     sts  cont_ms, temp						// Guarda el contador de ms actualizado en la RAM
                                 											
000123 d007                          rcall Parpadeo_LEDs_Alarma				// Llama a la rutina de parpadeo de LEDs de la alarma
                                 											
000124 915f                          pop  r21								// Restaura r21 desde la pila
000125 914f                          pop  r20								// Restaura r20 desde la pila
000126 912f                          pop  num_a_mostrar						// Restaura la variable de numero a mostrar desde la pila
000127 910f                          pop  temp								// Recupera el valor de SREG guardado
000128 bf0f                          out  SREG, temp							// Restaura el registro de estado
000129 910f                          pop  temp								// Restaura temp original
00012a 9518                          reti									// Retorna de la interrupciĂłn
                                 
                                 // Parpadeo de los LEDs del reloj
                                 Parpadeo_LEDs_Alarma:
00012b 3094                          cpi  estado, 4							// Verifica si el estado actual es 4 (configuracion de alarma)
00012c f461                          brne Salir_Parpadeo						// Si no es estado 4, sale sin hacer nada
                                 											
00012d 9100 0109                     lds  temp, cont_ms2						// Carga el segundo contador de ms
00012f 9503                          inc  temp								// Lo incrementa
000130 370d                          cpi  temp, 125							// Verifica si han pasado 125ms
000131 f429                          brne Guardar_ms2						// Si no, solo guarda el contador actualizado
000132 2700                          clr  temp								// Reinicia el contador al llegar a 125ms
000133 b14b                          in   r20, PORTD							// Lee el estado actual del Puerto D
000134 e053                          ldi  r21, (1 << PD0) | (1 << PD1)		// Mascara para los bits PD0 y PD1
000135 2745                          eor  r20, r21							// Alterna (toggle) PD0 y PD1 simultaneamente
000136 b94b                          out  PORTD, r20							// Escribe el nuevo estado en el Puerto D
                                 
                                 Guardar_ms2:
000137 9300 0109                     sts  cont_ms2, temp						// Guarda el contador de ms2 actualizado en RAM
                                 Salir_Parpadeo:
000139 9508                          ret										// Retorna al llamador
                                 
                                 // Digitos a mostrar en los displays
                                 Enviar_a_Puertos:
                                     // Asegurar que el dĂ­gito estĂˇ en rango 0-9
00013a 302a                          cpi  num_a_mostrar, 10					// Verifica que el digito sea valido 
00013b f018                          brlo Enviar_Seguro      				// Si es menor que 10, procede normalmente
00013c e020                          ldi  num_a_mostrar, 0   				// Si es menor o igual a 10 es invalido, fuerza a mostrar 0 por seguridad
00013d b90b                      	out PORTD, temp							// Limpia el puerto D 
00013e 9508                      	ret										// Sale sin continuar
                                     
                                 Enviar_Seguro:
                                     // Cargar la direcciĂłn base de la tabla (multiplicada por 2 para bytes)
00013f e0f0                          ldi  ZH, high(Tabla7Seg << 1)			// Carga laÂ´parte alta de la direcciĂłn de la tabla en ZH	
000140 e6e8                          ldi  ZL, low(Tabla7Seg << 1)			// Carga laÂ´parte baja de la direcciĂłn de la tabla en ZL
                                     
                                     // Sumar el Ă­ndice (num_a_mostrar) al puntero Z de 16 bits
000141 0fe2                          add  ZL, num_a_mostrar					// Suma el indice al byte bajo del puntero Z
000142 2700                          clr  temp               				// Limpia temp para usarlo como carry
000143 1ff0                          adc  ZH, temp           				// Propaga el acarreo al byte alto de Z si ZL se desbordĂł
                                     
                                     // Leer el valor de la tabla
000144 9144                          lpm  r20, Z								// Lee el byte de la tabla de 7 segmentos
                                 
000145 2755                          clr  r21								// Limpia r21 para construir el valor a escribir en PORTB
000146 fb40                          bst  r20, 0  							// Extrae el bit 0 de r20 en el flag T
000147 f954                          bld r21, 4   							// Deposita el flag T en el bit 4 de r21 (PB4 = seg A)
000148 fb41                          bst  r20, 1  							// Extrae el bit 1 en T
000149 f953                          bld r21, 3    							// Deposita en bit 3 de r21 (PB3 = seg B)
00014a fb42                          bst  r20, 2  							// Extrae el bit 2 en T
00014b f952                          bld r21, 2    							// Deposita en bit 2 de r21 (PB2 = seg C)
00014c fb43                          bst  r20, 3  							// Extrae el bit 3 en T
00014d f951                          bld r21, 1    							// Deposita en bit 1 de r21 (PB1 = seg D)
00014e fb44                          bst  r20, 4  							// Extrae el bit 4 en T
00014f f950                          bld r21, 0    							// Deposita en bit 0 de r21 (PB0 = seg E)
                                 
000150 b105                          in   temp, PORTB						// Lee el estado actual de PORTB
000151 7e00                          andi temp, 0b11100000        			// Conserva solo los bits PB5-PB7 (LED dos puntos y otros)
000152 2b05                          or   temp, r21							// Combina con los nuevos valores de segmentos A-E
000153 b905                          out  PORTB, temp						// Escribe el resultado final en PORTB
                                 											
000154 2766                          clr  r22								// Limpia r22 para construir el valor a escribir en PORTD
000155 fb45                          bst  r20, 5  							// Extrae el bit 5 de r20 (segmento F) en T
000156 f967                          bld r22, 7     							// Deposita en bit 7 de r22 (PD7 = seg F)
000157 fb46                          bst  r20, 6  							// Extrae el bit 6 (segmento G) en T
000158 f966                          bld r22, 6     							// Deposita en bit 6 de r22 (PD6 = seg G)
                                 											
000159 b10b                          in   temp, PORTD						// Lee el estado actual de PORTD
00015a 730f                      	andi temp, 0b00111111    				// Limpia solo los bits PD7 y PD6 (segmentos F y G)
00015b 2b06                      	or   temp, r22           				// Combina con los nuevos valores de seg F y G
00015c b90b                      	out  PORTD, temp						// Escribe el resultado final en PORTD y retorna (sin ret explicito)
                                 
                                 PCI1_ISR:
00015d 930f                          push temp								// Guarda temp en la pila						
00015e b70f                          in   temp, SREG							// Lee el registro de estado
00015f 930f                          push temp								// Guarda SREG
000160 934f                          push r20								// Guarda r20
                                 
000161 b106                          in   temp, PINC							// Lee el estado actual de los pines del Puerto C (botones)
                                 
000162 fd04                          sbrc temp, 4             				// Salta si el bit 4 esta limpio (PC4 presionado = 0)
000163 c003                          rjmp Chk_PC0							// Si PC4 NO esta presionado, revisa el siguiente boton
000164 d02e                          rcall Cambiar_Estado					// PC4 presionado: cambia el modo/estado del reloj
000165 d019                          rcall Esperar_Soltar_PC4				// Espera a que se suelte el boton PC4
000166 c013                          rjmp Fin_PCI1							// Termina el manejo de la interrupcion
                                 
                                 Chk_PC0:
000167 fd00                          sbrc temp, 0             				// Salta si el bit 0 esta limpio (PC0 presionado = 0)
000168 c003                          rjmp Chk_PC1							// Si PC0 NO esta presionado, revisa el siguiente
000169 d090                          rcall Accion_Up_D1						// PC0 presionado: incrementa el primer par de digitos
00016a d018                          rcall Esperar_Soltar_PC0				// Espera a que se suelte PC0
00016b c00e                          rjmp Fin_PCI1
                                 
                                 Chk_PC1:
00016c fd01                          sbrc temp, 1             				// Salta si PC1 esta limpio (presionado)
00016d c003                          rjmp Chk_PC2							// Si no esta presionado, revisa el siguiente
00016e d0b0                          rcall Accion_Down_D1					// PC1 presionado: decrementa el primer par de digitos
00016f d017                          rcall Esperar_Soltar_PC1				// Espera a que se suelte PC1
000170 c009                          rjmp Fin_PCI1
                                 
                                 Chk_PC2:
000171 fd02                          sbrc temp, 2             				// Salta si PC2 esta limpio (presionado)
000172 c003                          rjmp Chk_PC3							// Si no esta presionado, revisa el siguiente
000173 d0d1                          rcall Accion_Up_D2						// PC2 presionado: incrementa el segundo par de digitos
000174 d016                          rcall Esperar_Soltar_PC2				// Espera a que se suelte PC2
000175 c004                          rjmp Fin_PCI1
                                 
                                 Chk_PC3:
000176 fd03                          sbrc temp, 3             				// Salta si PC3 esta limpio (presionado)
000177 c002                          rjmp Fin_PCI1							// Si PC3 NO esta presionado, no hay accion (sale)
000178 d0ee                          rcall Accion_Down_D2					// PC3 presionado: decrementa el segundo par de digitos
000179 d015                          rcall Esperar_Soltar_PC3				// Espera a que se suelte PC3
                                 
                                 Fin_PCI1:
00017a 914f                          pop  r20								// Restaura r20
00017b 910f                          pop  temp								// Recupera SREG guardado
00017c bf0f                          out  SREG, temp							// Restaura el registro de estado
00017d 910f                          pop  temp								// Restaura temp
00017e 9518                          reti									// Retorna de la interrupcion
                                 
                                 // Espera para la verificacion de los botones
                                 Esperar_Soltar_PC4:
00017f b106                          in   temp, PINC							// Lee el estado de los pines del Puerto C
000180 ff04                          sbrs temp, 4							// Salta si el bit 4 esta en 1 (boton suelto)
000181 cffd                          rjmp Esperar_Soltar_PC4					// Si sigue en 0 (presionado), espera en bucle
000182 9508                          ret										// El boton fue soltado, retorna
                                 											
                                 Esperar_Soltar_PC0:							
000183 b106                          in   temp, PINC							// Lee los pines del Puerto C
000184 ff00                          sbrs temp, 0							// Salta si PC0 esta en 1 (suelto)
000185 cffd                          rjmp Esperar_Soltar_PC0					// Si sigue presionado, espera
000186 9508                          ret										
                                 											
                                 Esperar_Soltar_PC1:							
000187 b106                          in   temp, PINC							// Lee los pines del Puerto C
000188 ff01                          sbrs temp, 1							// Salta si PC1 esta en 1 (suelto)
000189 cffd                          rjmp Esperar_Soltar_PC1					// Si sigue presionado, espera
00018a 9508                          ret										
                                 											
                                 Esperar_Soltar_PC2:						
00018b b106                          in   temp, PINC							// Lee los pines del Puerto C
00018c ff02                          sbrs temp, 2							// Salta si PC2 esta en 1 (suelto)
00018d cffd                          rjmp Esperar_Soltar_PC2					// Si sigue presionado, espera
00018e 9508                          ret										
                                 											
                                 Esperar_Soltar_PC3:							
00018f b106                          in   temp, PINC							// Lee los pines del Puerto C
000190 ff03                          sbrs temp, 3							// Salta si PC3 esta en 1 (suelto)
000191 cffd                          rjmp Esperar_Soltar_PC3					// Si sigue presionado, espera
000192 9508                          ret
                                 
                                 // Cambios de estado del reloj
                                 Cambiar_Estado:
                                     ; Primero verificar si la alarma esta sonando
000193 9100 0107                     lds  temp, alarma_activa
000195 3001                          cpi  temp, 1
000196 f429                          brne Modo_Normal
                                 
                                     ; Si esta sonando -> apagarla y NO cambiar estado
000197 2700                          clr  temp
000198 9300 0107                     sts  alarma_activa, temp
00019a 9845                          cbi  PORTC, 5
00019b 9508                          ret
                                 
                                 Modo_Normal:
00019c 9593                          inc  estado
00019d 3095                          cpi  estado, 5
00019e f008                          brlo Est_Config_Check
00019f 2799                          clr  estado
                                 										
                                 Est_Config_Check:						
                                     // Estados 2,3,4 pausan el reloj	
0001a0 3092                          cpi  estado, 2							// Verifica si el estado es 2 o mayor
0001a1 f410                          brsh Est_Pausar							// Si estado >= 2, pausa el reloj
0001a2 2733                          clr  en_config							// Estado 0 o 1: reloj corre (en_config = 0)
0001a3 c002                          rjmp Actualizar_LEDs					// Actualiza los LEDs indicadores
                                 Est_Pausar:									//
0001a4 e031                          ldi  en_config, 1						// Pausa el reloj (en_config = 1)
0001a5 c000                      	rjmp Actualizar_LEDs					// Actualiza los LEDs indicadores
                                 											
                                 Actualizar_LEDs:							
0001a6 3092                          cpi  estado, 2							// Verifica si el estado es 2 o mayor
0001a7 f410                          brsh LED_Parpadeo    					// Si estado >= 2, activa el parpadeo del LED
                                     // Estados 0,1 -> encendido fijo
0001a8 9a2d                          sbi  PORTB, 5							// Enciende el LED dos puntos de forma fija
0001a9 9508                          ret
                                 LED_Parpadeo:
                                     // El parpadeo lo maneja Timer0, solo Setupear contador
0001aa 2700                          clr  temp								// Limpia temp
0001ab 9300 0108                     sts  cont_ms, temp						// Reinicia el contador de ms para empezar el parpadeo desde cero
0001ad 9508                          ret
                                 
                                 // Rutinas de incremento desde el Timer 1
                                 Inc_Minutos:
0001ae 9100 0101                     lds  temp, minutos						// Carga el valor actual de minutos
0001b0 9503                          inc  temp								// Incrementa los minutos
0001b1 330c                          cpi  temp, 60							// Compara con el limite de 60 minutos
0001b2 f431                          brne Guardar_IMin						// Si no llego a 60, guarda el nuevo valor
0001b3 2700                          clr  temp								// Si llego a 60, reinicia a 0
0001b4 9300 0101                     sts  minutos, temp						// Guarda minutos = 0 en RAM
0001b6 d006                          rcall Inc_Horas							// Llama a incrementar las horas
0001b7 d012                      	rcall Verificar_Alarma 
0001b8 9508                          ret
                                 Guardar_IMin:
0001b9 9300 0101                     sts  minutos, temp						// Guarda el nuevo valor de minutos en RAM
0001bb d00e                      	rcall Verificar_Alarma 
0001bc 9508                          ret
                                 
                                 Inc_Horas:
0001bd 9100 0102                     lds  temp, horas						// Carga el valor actual de horas
0001bf 9503                          inc  temp								// Incrementa las horas
0001c0 3108                          cpi  temp, 24							// Compara con el limite de 24 horas
0001c1 f429                          brne Guardar_IHor						// Si no llego a 24, guarda el nuevo valor
0001c2 2700                          clr  temp								// Si llego a 24, reinicia a 0 
0001c3 9300 0102                     sts  horas, temp						// Guarda horas = 0
0001c5 d01b                          rcall Inc_Dia							// Llama a incrementar el dia
0001c6 9508                          ret
                                 Guardar_IHor:
0001c7 9300 0102                     sts  horas, temp						// Guarda el nuevo valor de horas en RAM
0001c9 9508                          ret
                                 
                                 // Verificar alarma 
                                 Verificar_Alarma:
0001ca 9140 0102                     lds  r20, horas
0001cc 9150 0105                     lds  r21, alarma_horas
0001ce 1745                          cp   r20, r21
0001cf f459                          brne Alarma_No
0001d0 9140 0101                     lds  r20, minutos
0001d2 9150 0106                     lds  r21, alarma_minutos
0001d4 1745                          cp   r20, r21
0001d5 f429                          brne Alarma_No
                                     // Hora y minutos coinciden: activar buzzer
0001d6 e001                          ldi  temp, 1
0001d7 9300 0107                     sts  alarma_activa, temp
0001d9 9a45                          sbi  PORTC, 5
0001da 9508                          ret
                                 Alarma_No:
0001db 9100 0107                     lds  temp, alarma_activa
0001dd 3001                          cpi  temp, 1
0001de f009                          breq Mantener_Buzzer     ; Si alarma sigue activa, mantener buzzer
0001df 9845                          cbi  PORTC, 5            ; Si no, apagar
                                 Mantener_Buzzer:
0001e0 9508                          ret										// Retorna a llamador
                                 
                                 Inc_Dia:
0001e1 9140 0103                     lds  r20, dia							// Carga el dia actual
0001e3 9150 0104                     lds  r21, mes							// Carga el mes actual (necesario para saber cuantos dias tiene)
0001e5 9543                          inc  r20								// Incrementa el dia
0001e6 d0a2                          rcall Dias_Del_Mes						// Obtiene el maximo de dias del mes actual en r22
0001e7 1746                          cp   r20, r22							// Compara el nuevo dia con el maximo + 1
0001e8 f028                          brlo Guardar_IDia						// Si es menor, el dia es valido, lo guarda
0001e9 e041                          ldi  r20, 1								// Si supera el maximo, reinicia el dia a 1
0001ea 9340 0103                     sts  dia, r20							// Guarda dia = 1 en RAM
0001ec d004                          rcall Inc_Mes							// Llama a incrementar el mes
0001ed 9508                          ret
                                 Guardar_IDia:
0001ee 9340 0103                     sts  dia, r20							// Guarda el nuevo valor de dia en RAM
0001f0 9508                          ret
                                 
                                 Inc_Mes:
0001f1 9100 0104                     lds  temp, mes							// Carga el mes actual
0001f3 9503                          inc  temp								// Incrementa el mes
0001f4 300d                          cpi  temp, 13							// Compara con 13 (limite: el mes 13 no existe)
0001f5 f008                          brlo Guardar_IMes						// Si es menor que 13, el mes es valido
0001f6 e001                          ldi  temp, 1							// Si llego a 13, reinicia a enero 
                                 Guardar_IMes:
0001f7 9300 0104                     sts  mes, temp							// Guarda el nuevo mes en RAM
0001f9 9508                          ret
                                 
                                 // Acciones de up/down segun el estado actual
                                 Accion_Up_D1:
0001fa 3092                          cpi  estado, 2							// Verifica si estamos en modo configurar hora
0001fb f029                          breq Up_Horas							// Si si, incrementa las horas
0001fc 3093                          cpi  estado, 3							// Verifica si estamos en modo configurar fecha
0001fd f061                          breq Up_Dias							// Si si, incrementa el dia
0001fe 3094                          cpi  estado, 4							// Verifica si estamos en modo configurar alarma
0001ff f0b1                          breq Up_Alarma_Hora						// Si si, incrementa la hora de alarma
000200 9508                          ret										// En otro estado, no hace nada
                                 
                                 Up_Horas:
000201 9100 0102                     lds  temp, horas						// Carga el valor actual de horas
000203 9503                          inc  temp								// Incrementa las horas
000204 3108                          cpi  temp, 24							// Verifica el limite de 24 horas
000205 f008                          brlo Guardar_Up_Hora					// Si es menor que 24, guarda directamente
000206 2700                          clr  temp								// Si llego a 24, reinicia a 0
                                 
                                 Guardar_Up_Hora:
000207 9300 0102                     sts  horas, temp						// Guarda las horas actualizadas en RAM
000209 9508                          ret
                                 
                                 Up_Dias:
00020a 9140 0103                     lds  r20, dia							// Carga el dia actual
00020c 9150 0104                     lds  r21, mes							// Carga el mes actual
00020e 9543                          inc  r20								// Incrementa el dia
00020f d079                          rcall Dias_Del_Mes						// Obtiene el maximo de dias del mes en r22
000210 1746                          cp   r20, r22							// Compara con el maximo + 1
000211 f008                          brlo Guardar_Up_Dia						// Si es valido, lo guarda
000212 e041                          ldi  r20, 1								// Si supera el maximo, vuelve al dia 1
                                 Guardar_Up_Dia:
000213 9340 0103                     sts  dia, r20							// Guarda el dia actualizado en RAM
000215 9508                          ret
                                 
                                 Up_Alarma_Hora:
000216 9100 0105                     lds  temp, alarma_horas					// Carga la hora de alarma actual
000218 9503                          inc  temp								// Incrementa la hora de alarma
000219 3108                          cpi  temp, 24							// Verifica el limite de 24 horas
00021a f008                          brlo Guardar_Up_AH						// Si es valido, guarda
00021b 2700                          clr  temp								// Si llego a 24, reinicia a 0
                                 Guardar_Up_AH:
00021c 9300 0105                     sts  alarma_horas, temp					// Guarda la hora de alarma actualizada en RAM
00021e 9508                          ret
                                 
                                 Accion_Down_D1:
00021f 3092                          cpi  estado, 2							// Verifica modo configurar hora
